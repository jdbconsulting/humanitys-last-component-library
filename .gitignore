#################
## Generated Files
#################

# Vite plugin (vite/plugins/hlcl-build-assets.ts) regenerates these on every
# `npm run dev` and `npm run build` from `src/lib/schema.ts` and the curated
# subset of hlcl/. All four are checked-in-only as build outputs, never as
# source. The standalone `tsx vite/scripts/regen.ts` (also wired into the
# `prepare` and `check` npm scripts) regenerates them on a fresh clone.
hlcl/build-config.schema.json
hlcl/factory-defaults.json
static/hlcl-build-inputs.tgz
src/lib/_generated/catalog.ts
src/lib/_generated/presets.ts

# `build/` matches both directories that get generated in this repo:
#
#   /build/                    SvelteKit's static-adapter output (the
#                              site bundle that ships to GitHub Pages).
#   hlcl/build/                The Python pipeline's output. Split into
#       intermediate/          per-vendor footprints JSONs, the merged
#                              house-footprints.json, parametric .step
#                              models
#       output/                user-facing .xls / .DbLib / .PcbLib /
#                              .SchLib / standards/standards.{tex,md}
build

#################
## CAD step models
#################

# STEP / IGES 3D models -- large binaries, regenerated by
# hlcl/house/build_step_models.py
*.step
*.STEP

#################
## Vendor reference data (downloaded, not source)
#################

# Samsung MLCC S-parameter / touchstone libraries. Thousands of small
# files downloaded from Samsung's design tool. Re-fetch with the vendor
# scripts; do not commit.
hlcl/vendors/samsung/General/
hlcl/vendors/samsung/Automotive/

# Murata LQ-series datasheet PDFs, fetched on-demand by
# `hlcl/vendors/murata/scrape_lq_pdfs.py`. ~30 MB of binaries that
# the LQM/LQW build scripts re-download as needed; not source.
.pdf_cache/
