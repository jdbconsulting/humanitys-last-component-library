# Windows image file caches
Thumbs.db
 
# Folder config file
Desktop.ini
 
# Mac crap
.DS_Store

# Windows / WSL "Zone.Identifier" alternate-data-stream sidecars that
# Windows attaches to anything downloaded from the internet. They turn
# into visible ":Zone.Identifier" files on a Linux/WSL filesystem and
# are pure metadata noise -- never source.
*:Zone.Identifier

